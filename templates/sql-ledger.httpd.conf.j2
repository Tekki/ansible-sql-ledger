Alias /{{ sl_httpd_url }} {{ sl_httpd_path }}/
<Directory {{ sl_httpd_path }}>
{% if sl_httpd_whitelist is defined %}
  Require ip {{ sl_httpd_whitelist | join(' ') }}
{% endif %}
  AllowOverride All
  AddHandler cgi-script .pl
  Options ExecCGI Includes FollowSymlinks
  Order Allow,Deny
  Allow from All
</Directory>

<Directory {{ sl_httpd_path }}/config>
  Order Deny,Allow
  Deny from All
</Directory>

<Directory {{ sl_httpd_path }}/users>
  Order Deny,Allow
  Deny from All
</Directory>

<Directory {{ sl_httpd_path }}/bin>
  Order Deny,Allow
  Deny from All
</Directory>

<Directory {{ sl_httpd_path }}/SL>
  Order Deny,Allow
  Deny from All
</Directory>

<Directory {{ sl_httpd_path }}/sql>
  Order Deny,Allow
  Deny from All
</Directory>

<Directory {{ sl_httpd_path }}/templates>
  Order Deny,Allow
  Deny from All
</Directory>

<Directory {{ sl_httpd_path }}/locale>
  Order Deny,Allow
  Deny from All
</Directory>
{% if sl_protect_admin %}

<Directory {{ sl_httpd_path }}>
  <Files "admin.pl">
{% if sl_httpd_whitelist is defined %}
    <RequireAll>
      Require ip {{ sl_httpd_whitelist | join(' ') }}
      Require valid-user
    </RequireAll>
{% else %}
    Require valid-user
{% endif %}
    AuthName "SQL-Ledger Admin"
    AuthType Basic
    AuthUserFile {{ sl_httpd_config }}/.slpasswd
  </Files>
</Directory>
{% endif %}
